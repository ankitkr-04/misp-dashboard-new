# Example configuration for local development and docker-compose.
GEMINI_API_KEY=your_gemini_api_key_here
OTX_API_KEY=
DEFAULT_DEMO_MODE=true
DEFAULT_DATA_SOURCE=public_misp
DEFAULT_SIMULATION_PROFILE=balanced
DEFAULT_ACTIVE_HQ_IDS=nyc,mumbai,bengaluru
WS_BROADCAST_INTERVAL_SECONDS=2.0
GOD_MODE_BURST_COUNT=100
GOD_MODE_BURST_INTERVAL=0.05
MAX_ARCS_ON_GLOBE=50
PUBLIC_MISP_FEED_URL=https://www.botvrij.eu/data/feed-osint/manifest.json
PUBLIC_MISP_EVENT_LIMIT=14
PUBLIC_MISP_MAX_ITEMS=90
PUBLIC_MISP_IPS_PER_EVENT=3
LIVE_FEED_REFRESH_MINUTES=30
LIVE_FEED_REQUEST_TIMEOUT_SECONDS=12.0
AUTO_REFRESH_LIVE_FEED=true
ENABLE_IP_GEOLOOKUP=true
IP_GEOLOOKUP_URL_TEMPLATE=https://ipwho.is/{ip}
